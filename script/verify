#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "pathname"
require "yaml"

root = Pathname.new(__dir__).join("..").expand_path
skills = {
  "develop-hotwire-native" => root.join("skills/develop-hotwire-native"),
  "deploy-hotwire-native-ios" => root.join("skills/deploy-hotwire-native-ios")
}
errors = []

skill_markdowns = skills.to_h do |name, skill|
  unless skill.join("SKILL.md").file?
    errors << "Missing #{name}/SKILL.md."
    next [name, ""]
  end

  markdown = skill.join("SKILL.md").read
  errors << "#{name} frontmatter name does not match its directory." unless markdown.match?(/^name: #{Regexp.escape(name)}$/)
  [name, markdown]
end

required_references = {
  "develop-hotwire-native" => %w[push-notifications.md],
  "deploy-hotwire-native-ios" => %w[
    workflow-selection.md
    project-and-environments.md
    signing-and-capabilities.md
    ci-and-testflight.md
    troubleshooting.md
    evidence-ledger.md
  ]
}

required_references.each do |name, references|
  skill = skills.fetch(name)
  markdown = skill_markdowns.fetch(name)

  references.each do |reference|
    errors << "Missing #{name} task reference #{reference}." unless skill.join("references", reference).file?
    errors << "#{name}/SKILL.md does not route to #{reference}." unless markdown.include?("references/#{reference}")
  end
end

if skills.fetch("develop-hotwire-native").join("references/distribution-and-signing.md").exist?
  errors << "Deployment guidance still lives inside develop-hotwire-native."
end

agent_neutral_markdown = skills.values.flat_map do |skill|
  [skill.join("SKILL.md"), *skill.join("references").glob("*.md")].select(&:file?).map(&:read)
end.join("\n")

%w[Codex Claude Gemini Cursor].each do |host|
  errors << "Core Skills mention host-specific name #{host.inspect}." if agent_neutral_markdown.match?(/\b#{Regexp.escape(host)}\b/)
end

manifest = JSON.parse(root.join(".codex-plugin/plugin.json").read)
version = manifest.fetch("version")
errors << "Plugin name is inconsistent." unless manifest["name"] == "hotwire-native-agent-kit"
errors << "Changelog does not contain version #{version}." unless root.join("CHANGELOG.md").read.include?("## #{version} -")

lock = YAML.load_file(root.join("upstream-lock.yml"))
unless lock.fetch("deployment_documentation_verified_on", "").match?(/\A\d{4}-\d{2}-\d{2}\z/)
  errors << "Deployment documentation verification date is missing or invalid."
end
lock.fetch("sources").each do |name, source|
  errors << "#{name} is missing an immutable commit." unless source.fetch("commit", "").match?(/\A[0-9a-f]{40}\z/)
end

development_skill = skills.fetch("develop-hotwire-native")
licenses = development_skill.join("assets/templates/bridge-form/LICENSES.md")
errors << "Adapted bridge templates are missing their accompanying license notices." unless licenses.file?
{
  "form_controller.js" => "Copyright (c) 2025 Joseph Masilotti",
  "FormComponent.swift" => "Copyright (c) 2024 Hotwire",
  "FormComponent.kt" => "Copyright (c) 2024 37signals LLC"
}.each do |filename, notice|
  errors << "#{filename} is missing its upstream copyright header." unless development_skill.join("assets/templates/bridge-form", filename).read.include?(notice)
  errors << "LICENSES.md is missing the notice for #{filename}." unless licenses.read.include?(notice)
end

Dir.glob(development_skill.join("assets/templates/path-configuration/*.json")).each do |path|
  JSON.parse(File.read(path))
end

Dir.glob(root.join("**/*.md"), File::FNM_DOTMATCH).each do |path|
  relative = Pathname.new(path).relative_path_from(root)
  File.read(path).scan(/\[[^\]]*\]\(([^)]+)\)/).flatten.each do |target|
    next if target.match?(%r{\A(?:https?://|mailto:|#)})

    destination = target.split("#", 2).first
    resolved = Pathname.new(path).dirname.join(destination).cleanpath
    errors << "#{relative}: missing link target #{target.inspect}." unless resolved.exist?
  end
end

skills.each_value do |skill|
  Dir.glob(skill.join("scripts/*")).each do |path|
    next unless File.file?(path)

    errors << "#{Pathname.new(path).relative_path_from(root)} is not executable." unless File.executable?(path)
  end
end

Dir.glob(root.join("**/*"), File::FNM_DOTMATCH).select { |path| File.file?(path) }.each do |path|
  next if path == root.join(".git").to_s || path.include?("/.git/")

  content = File.binread(path)
  next unless content.valid_encoding?

  private_home_prefix = "/" + "Users/"
  errors << "#{Pathname.new(path).relative_path_from(root)} contains a private absolute path." if content.include?(private_home_prefix)
end

abort errors.join("\n") unless errors.empty?

puts "Release structure verified for #{manifest.fetch('name')} #{version} (#{skills.keys.join(', ')})."
